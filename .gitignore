# macOS
.DS_Store

# Rust
target/

# Node.js
node_modules/

# napi-rs compiled binaries
*.node

# napi-rs generated files (produced by `npm run build`)
# The root-level files are the canonical outputs; crate-level copies are
# stale artifacts from older build configurations and must not be committed.
/index.js
/index.d.ts
crates/*/index.js
crates/*/index.d.ts

# npm platform packages (generated by `napi create-npm-dirs`)
npm/

# Smoke report artifacts generated by `npm run test:smoke-report`
/xshot-smoke-reports/