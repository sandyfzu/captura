{
  "name": "xshot",
  "version": "0.1.0",
  "description": "Cross-platform screen capture for Node.js — a high-performance native module with a fully typed async TypeScript API",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "xshot",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": ">= 20.3.0"
  },
  "scripts": {
    "build": "napi build --platform --release -p xshot -o .",
    "build:debug": "napi build --platform -p xshot -o .",
    "test": "node --test __tests__/integration.mts",
    "typecheck": "tsc --noEmit",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^22.19.15",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "lint-staged": {
    "*.rs": "rustfmt"
  }
}
