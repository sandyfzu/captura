{
  "name": "xshot",
  "version": "0.0.0",
  "description": "Cross-platform screen capture for Node.js — a production-grade Rust native module wrapping xcap via napi-rs, with a fully typed async TypeScript API",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "xshot",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": ">= 20.3.0"
  },
  "scripts": {
    "build": "napi build --platform --release -p xshot",
    "build:debug": "napi build --platform -p xshot",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
