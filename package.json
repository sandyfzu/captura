{
  "name": "captura",
  "version": "1.0.0",
  "description": "Cross-platform screen capture for Node.js — a high-performance native module with a fully typed async TypeScript API",
  "keywords": [
    "screenshot",
    "screen-capture",
    "screen",
    "capture",
    "native",
    "napi-rs",
    "rust",
    "xcap"
  ],
  "homepage": "https://github.com/sandyfzu/captura#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandyfzu/captura.git"
  },
  "bugs": {
    "url": "https://github.com/sandyfzu/captura/issues"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./errors": {
      "types": "./errors.d.ts",
      "import": "./errors.mjs",
      "require": "./errors.js",
      "default": "./errors.js"
    },
    "./package.json": "./package.json"
  },
  "napi": {
    "binaryName": "captura",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": ">= 20.3.0"
  },
  "scripts": {
    "build": "napi build --platform --release -p captura -o .",
    "build:debug": "napi build --platform -p captura -o .",
    "test": "node --test __tests__/integration.mts",
    "test:smoke-report": "npm run build && node __tests__/smoke-report.mts",
    "typecheck": "tsc --noEmit",
    "create:npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts",
    "prepublish:napi": "napi prepublish -t npm --no-gh-release --skip-optional-publish",
    "prepublishOnly": "npm run prepublish:napi",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.3"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "errors.js",
    "errors.mjs",
    "errors.d.ts",
    "CHANGELOG.md"
  ],
  "lint-staged": {
    "*.rs": "rustfmt"
  }
}
