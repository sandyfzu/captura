#!/usr/bin/env sh

# ──────────────────────────────────────────────────────────────────────────────
# pre-commit — Auto-format staged Rust files before committing
# ──────────────────────────────────────────────────────────────────────────────
# Runs rustfmt on staged .rs files only, via lint-staged. Partial staging
# (git add -p) is handled correctly: lint-staged stashes unstaged changes,
# formats the staged files, re-stages the formatted output, then restores the
# stash — ensuring only intentionally staged content enters the commit.
# ──────────────────────────────────────────────────────────────────────────────

npx lint-staged
